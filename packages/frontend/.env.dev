# dev 環境デプロイ用ビルド設定。
# vite build --mode dev のときに .env / .env.local より優先して読まれる。
# 手元で sam deploy する際は必ず `pnpm build:dev` を経由すること。

# MSW はデプロイ時には必ず無効化する
VITE_USE_MSW=false

# dev 環境ではスタブログインを許容する（バックエンド側 AUTH_STUB_ENABLED と合わせて両方有効で動作）
VITE_AUTH_STUB_ENABLED=true

# OAuth ClientID / ClientSecret / RedirectURI 用の VITE_* は意図的に置かない:
#   - ClientID/Secret は backend が SecretsManager から取得して使用 (frontend src は未参照)
#   - RedirectURI は src/auth/useAuth.ts で window.location.origin から実行時生成
