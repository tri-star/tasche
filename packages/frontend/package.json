{
  "name": "@tasche/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "openapi:update": "orval --config orval.config.ts",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode dev",
    "build:prod": "tsc -b && vite build --mode prod",
    "lint": "biome check . && tsc -b --noEmit",
    "format": "biome check --write .",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "node scripts/run-e2e-with-backend.mjs",
    "test:e2e:ui": "node scripts/run-e2e-with-backend.mjs --ui",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "cmdk": "^1.0.0",
    "@tanstack/react-query": "^5.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "jotai": "^2.20.2",
    "lucide-react": "^1.25.0",
    "oauth4webapi": "^3.8.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@faker-js/faker": "^10.5.0",
    "@fontsource/noto-sans-jp": "^5.3.0",
    "@fontsource/quicksand": "^5.3.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "orval": "^8.22.0",
    "postcss": "^8.5.20",
    "tailwindcss": "^4.3.3",
    "typescript": "7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
