{
  "name": "@tasche/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "openapi:update": "orval --config orval.config.ts",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode dev",
    "build:prod": "tsc -b && vite build --mode prod",
    "lint": "biome check . && tsc -b --noEmit",
    "format": "biome check --write .",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "node scripts/run-e2e-with-backend.mjs",
    "test:e2e:ui": "node scripts/run-e2e-with-backend.mjs --ui",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-toggle": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.14",
    "cmdk": "^1.0.0",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "jotai": "^2.20.1",
    "lucide-react": "^1.23.0",
    "oauth4webapi": "^3.8.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@faker-js/faker": "^10.5.0",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@fontsource/quicksand": "^5.2.10",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.2",
    "jsdom": "^26.1.0",
    "msw": "^2.14.6",
    "orval": "^8.19.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
