VITE_DEV_PORT={%FRONTEND_DEV_PORT%}
VITE_API_BASE_URL=http://localhost:{%BACKEND_API_PORT%}
E2E_API_BASE_URL=http://localhost:{%E2E_BACKEND_API_PORT%}

# MSW (Mock Service Worker) を有効にするかどうか
# 開発環境では通常 true に設定します
VITE_USE_MSW=true

# Google OAuth 2.0
# Google Cloud Console で発行した OAuth 2.0 クライアント ID を指定
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
# OAuth コールバックURL (Google Cloud Console の "承認済みのリダイレクト URI" と一致させる)
VITE_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:{%FRONTEND_DEV_PORT%}/auth/callback

# スタブ認証を使用するか（AUTH_STUB_ENABLED 相当、開発環境のみ）
VITE_AUTH_STUB_ENABLED=true
