# 本ファイルはローカル開発用 .env のテンプレート。
# デプロイ時 (vite build --mode dev/prod) は .env.dev / .env.prod が
# 本ファイルや .env / .env.local より優先される。
# (Vite の env 優先度: .env.[mode].local > .env.[mode] > .env.local > .env)

VITE_DEV_PORT={%FRONTEND_DEV_PORT%}
VITE_API_BASE_URL=http://localhost:{%BACKEND_API_PORT%}
E2E_API_BASE_URL=http://localhost:{%E2E_BACKEND_API_PORT%}

# MSW (Mock Service Worker) を有効にするかどうか
# 開発環境では通常 true に設定します
VITE_USE_MSW=true

# スタブ認証を使用するか（AUTH_STUB_ENABLED 相当、開発環境のみ）
VITE_AUTH_STUB_ENABLED=true

# 注: Google OAuth の ClientID / ClientSecret / RedirectURI は frontend 側では持たない。
#   - ClientID/Secret は backend が SecretsManager (AWS) / .env (ローカル) から取得して使用
#   - RedirectURI は src/auth/useAuth.ts で window.location.origin から実行時生成
# Google Cloud Console の "承認済みのリダイレクト URI" にはローカル開発用の
# http://localhost:<VITE_DEV_PORT>/auth/callback を登録すること。

# Sentry（エラー監視）設定
# DSN が未設定（空）の場合は Sentry を初期化しない（ローカル/テストでは通常空のまま）。
# 本番相当ビルド（build:dev / build:prod）では .env.dev / .env.prod に実際の値を設定する。
VITE_SENTRY_DSN=
# 環境名（未設定時は Vite の MODE を使用）。例: production / staging
VITE_SENTRY_ENVIRONMENT=
# トレースサンプリング率（0〜1）。未設定時は 0（トレース無効・エラー捕捉のみ）
VITE_SENTRY_TRACES_SAMPLE_RATE=0
