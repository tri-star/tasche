COMPOSE_PROJECT_NAME={%COMPOSE_PROJECT_NAME%}
DB_CONTAINER_PORT={%DB_PORT%}
API_CONTAINER_PORT={%BACKEND_API_PORT%}
E2E_API_CONTAINER_PORT={%E2E_BACKEND_API_PORT%}


# Database
DATABASE_URL=postgresql+asyncpg://tasche:tasche_dev_password@localhost:5432/tasche

# 実行環境
# local / development / staging / production のいずれか
# production の場合は AUTH_STUB_ENABLED の値に関わらず常にスタブは無効となる
APP_ENV=local

# Google OAuth 2.0
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
# フロントのコールバックURL許可リスト（カンマ区切り、厳密一致検証する）
# VITE_DEV_PORT（packages/frontend/.env）と合わせること
GOOGLE_OAUTH_REDIRECT_URIS=http://localhost:4103/auth/callback

# セッション設定
SESSION_EXPIRES_SECONDS=604800  # 7日

# Cookie設定
# ローカル・E2E 等では false、本番は true
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS 許可オリジン（カンマ区切り）
# VITE_DEV_PORT（packages/frontend/.env）と合わせること
CORS_ALLOW_ORIGINS=http://localhost:4103

# スタブ認証（E2E・ローカル開発のみ）
# AUTH_STUB_ENABLED が true でも、APP_ENV=production の場合は無効
AUTH_STUB_ENABLED=true

LOG_LEVEL=debug
